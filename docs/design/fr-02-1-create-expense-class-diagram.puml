package "Feature Layer" {
  class ExpenseCreateComponent {
    - formBuilder: FormBuilder
    - currencyService: CurrencyService
    - expenseService: ExpenseService
    - store: Store
    + form
    + currencies: readonly CurrencyDefinition[]
    + baseCurrency: string
    + conversionLabel: string
    + categories: readonly Category[]
    + errorMessage: string
    + successMessage: string
    + ngOnInit(): void
    + onBaseCurrencyChange(currencyCode: string): void
    + onCreateExpense(): void
    - updateConversionLabel(): void
  }
}

package "Service Layer" {
  class ExpenseService {
    - authService: AuthService
    - auditLogService: AuditLogService
    - currencyService: CurrencyService
    + listCategories(): Observable<Category[]>
    + createExpense(request: CreateExpenseRequest): Observable<Expense>
    - seedCategoriesIfMissing(): void
    - getExpenses(): Expense[]
    - getCategories(): Category[]
  }

  class CurrencyService {
    + listSupportedCurrencies(): Observable<CurrencyDefinition[]>
    + isSupportedCurrency(code: string): boolean
    + getBaseCurrencyPreference(): CurrencyPreference
