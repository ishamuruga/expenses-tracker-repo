    + convertAmount(amount: number, sourceCurrency: string, targetCurrency: string): number | null
    - seedCurrencyDataIfMissing(): void
    - getCurrencies(): CurrencyDefinition[]
    - getExchangeRates(): ExchangeRate[]
  }

  class AuthService {
    + getCurrentUser(): Omit~AppUser, 'passwordHash'~ | null
    + isAuthenticated(): boolean
  }

  class AuditLogService {
    + appendLog(input): AuditLogEntry
    + getLogs(): AuditLogEntry[]
  }
}

package "Store Layer" {
  class ExpenseState {
    + items: readonly Expense[]
    + creating: boolean
    + error: string | null
  }

  class ExpenseActions <<action group>> {
    + createExpenseStarted
    + createExpenseSuccess
    + createExpenseFailure
  }

  class ExpenseReducer <<reducer>> {
    + initialExpenseState: ExpenseState
  }
}

package "Domain Models" {
  class Expense {
    + expenseId: string
